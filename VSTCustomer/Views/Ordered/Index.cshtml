    @{
    Func<int?, string> generateUrl = p => Url.Action(
        "Index", 
        "Ordered", 
        new { pageIndex = p, pageSize = Model.Pagination.PageSize }
        );
    }
<partial name="_Pagination" model="new { 
    currentPage = Model.Pagination.CurrentPage,
    countPages  = Model.Pagination.TotalPages,
    generateUrl = generateUrl
}" />
</body>
</html>